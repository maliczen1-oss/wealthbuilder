# Copy this file to .env and fill in your own values.
# NEVER commit .env, never paste its contents in chat, never share it.

# Generate a NEW token at app.metaapi.cloud (the one posted earlier is revoked).
# Use READ-ONLY scope if MetaApi's token creation UI allows restricting it —
# this server only needs read access for everything currently implemented.
METAAPI_TOKEN=your_metaapi_token_here

# Your MetaApi account ID (the one you shared earlier is fine to reuse,
# this is not a secret on its own — only the token is).
METAAPI_ACCOUNT_ID=8478f2a6-b1a2-4662-95c7-3713f0d83602

PORT=3000
