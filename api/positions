app.get('/api/history', async (req, res) => {
  try {
    const startTime = new Date(
      Date.now() - 90 * 24 * 60 * 60 * 1000
    );

    const endTime = new Date();

    const history =
      await connection.getDealsByTimeRange(
        startTime,
        endTime
      );

    res.json(history);

  } catch (err) {
    res.status(500).json({
      error: err.message
    });
  }
});
